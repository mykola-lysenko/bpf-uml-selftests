From 5be565df453a432eae9ceddf1be58b0af670ec8c Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Mon, 20 Apr 2026 18:58:49 -0400
Subject: [PATCH] bpf: add verification stubs for UML kernels without
 PERF_EVENTS

On User Mode Linux (UML), CONFIG_PERF_EVENTS and CONFIG_BPF_EVENTS are
unavailable because they depend on hardware performance counters and
kprobes.  This means tracing program types (KPROBE, TRACEPOINT,
PERF_EVENT, RAW_TRACEPOINT, TRACING) and LSM program types are not
registered.  BPF_MAP_TYPE_STACK_TRACE and BPF_MAP_TYPE_INODE_STORAGE
are also unavailable.

For static verification purposes (veristat), we only need the BPF
verifier to accept these program types — programs are never attached
or executed.

Add CONFIG_BPF_VERIFICATION_STUBS (default y on UML) that provides:

Tracing stubs:
- Minimal bpf_verifier_ops/bpf_prog_ops for all six tracing program
  types, delegating to bpf_base_func_proto() and
  bpf_tracing_btf_ctx_access().
- Callchain buffer stubs so BPF_MAP_TYPE_STACK_TRACE maps can be
  created.  Execution-time stubs use WARN_ON_ONCE since veristat
  never runs programs.

LSM stubs (when CONFIG_SECURITY is also set):
- Weak noinline bpf_lsm_* nop functions as BTF attach targets for
  SEC("lsm/...") programs.
- BTF ID sets for hook validation (bpf_lsm_hooks, sleepable, etc.)
  and bpf_lsm_verify_prog(), is_sleepable_hook(), is_trusted(),
  get_retval_range() implementations.
- Stub FS kfuncs (bpf_get_file_xattr, bpf_get_dentry_xattr, etc.)
  with BTF_KFUNCS registration for BPF_PROG_TYPE_LSM.
- BPF_MAP_TYPE_INODE_STORAGE via bpf_inode_storage.c.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
diff --git a/include/linux/bpf_lsm.h b/include/linux/bpf_lsm.h
index 643809cc7..9c16b8e39 100644
--- a/include/linux/bpf_lsm.h
+++ b/include/linux/bpf_lsm.h
@@ -12,7 +12,7 @@
 #include <linux/bpf_verifier.h>
 #include <linux/lsm_hooks.h>
 
-#ifdef CONFIG_BPF_LSM
+#if defined(CONFIG_BPF_LSM) || defined(CONFIG_BPF_VERIFICATION_STUBS)
 
 #define LSM_HOOK(RET, DEFAULT, NAME, ...) \
 	RET bpf_lsm_##NAME(__VA_ARGS__);
@@ -53,7 +53,7 @@ int bpf_set_dentry_xattr_locked(struct dentry *dentry, const char *name__str,
 int bpf_remove_dentry_xattr_locked(struct dentry *dentry, const char *name__str);
 bool bpf_lsm_has_d_inode_locked(const struct bpf_prog *prog);
 
-#else /* !CONFIG_BPF_LSM */
+#else /* !CONFIG_BPF_LSM && !CONFIG_BPF_VERIFICATION_STUBS */
 
 static inline bool bpf_lsm_is_sleepable_hook(u32 btf_id)
 {
@@ -104,6 +104,6 @@ static inline bool bpf_lsm_has_d_inode_locked(const struct bpf_prog *prog)
 {
 	return false;
 }
-#endif /* CONFIG_BPF_LSM */
+#endif /* CONFIG_BPF_LSM || CONFIG_BPF_VERIFICATION_STUBS */
 
 #endif /* _LINUX_BPF_LSM_H */
diff --git a/include/linux/bpf_types.h b/include/linux/bpf_types.h
index b13de31e1..8359b8f99 100644
--- a/include/linux/bpf_types.h
+++ b/include/linux/bpf_types.h
@@ -35,7 +35,7 @@ BPF_PROG_TYPE(BPF_PROG_TYPE_SK_MSG, sk_msg,
 BPF_PROG_TYPE(BPF_PROG_TYPE_FLOW_DISSECTOR, flow_dissector,
 	      struct __sk_buff, struct bpf_flow_dissector)
 #endif
-#ifdef CONFIG_BPF_EVENTS
+#if defined(CONFIG_BPF_EVENTS) || defined(CONFIG_BPF_VERIFICATION_STUBS)
 BPF_PROG_TYPE(BPF_PROG_TYPE_KPROBE, kprobe,
 	      bpf_user_pt_regs_t, struct pt_regs)
 BPF_PROG_TYPE(BPF_PROG_TYPE_TRACEPOINT, tracepoint,
@@ -72,10 +72,10 @@ BPF_PROG_TYPE(BPF_PROG_TYPE_STRUCT_OPS, bpf_struct_ops,
 	      void *, void *)
 BPF_PROG_TYPE(BPF_PROG_TYPE_EXT, bpf_extension,
 	      void *, void *)
-#ifdef CONFIG_BPF_LSM
+#if defined(CONFIG_BPF_LSM) || defined(CONFIG_BPF_VERIFICATION_STUBS)
 BPF_PROG_TYPE(BPF_PROG_TYPE_LSM, lsm,
 	       void *, void *)
-#endif /* CONFIG_BPF_LSM */
+#endif
 #endif
 BPF_PROG_TYPE(BPF_PROG_TYPE_SYSCALL, bpf_syscall,
 	      void *, void *)
@@ -101,12 +101,12 @@ BPF_MAP_TYPE(BPF_MAP_TYPE_PERCPU_HASH, htab_percpu_map_ops)
 BPF_MAP_TYPE(BPF_MAP_TYPE_LRU_HASH, htab_lru_map_ops)
 BPF_MAP_TYPE(BPF_MAP_TYPE_LRU_PERCPU_HASH, htab_lru_percpu_map_ops)
 BPF_MAP_TYPE(BPF_MAP_TYPE_LPM_TRIE, trie_map_ops)
-#ifdef CONFIG_PERF_EVENTS
+#if defined(CONFIG_PERF_EVENTS) || defined(CONFIG_BPF_VERIFICATION_STUBS)
 BPF_MAP_TYPE(BPF_MAP_TYPE_STACK_TRACE, stack_trace_map_ops)
 #endif
 BPF_MAP_TYPE(BPF_MAP_TYPE_ARRAY_OF_MAPS, array_of_maps_map_ops)
 BPF_MAP_TYPE(BPF_MAP_TYPE_HASH_OF_MAPS, htab_of_maps_map_ops)
-#ifdef CONFIG_BPF_LSM
+#if defined(CONFIG_BPF_LSM) || defined(CONFIG_BPF_VERIFICATION_STUBS)
 BPF_MAP_TYPE(BPF_MAP_TYPE_INODE_STORAGE, inode_storage_map_ops)
 #endif
 BPF_MAP_TYPE(BPF_MAP_TYPE_TASK_STORAGE, task_storage_map_ops)
diff --git a/include/linux/perf_event.h b/include/linux/perf_event.h
index 48d851fbd..107886448 100644
--- a/include/linux/perf_event.h
+++ b/include/linux/perf_event.h
@@ -2021,7 +2021,22 @@ perf_event_period(struct perf_event *event, u64 value)			{ return -EINVAL; }
 static inline u64
 perf_event_pause(struct perf_event *event, bool reset)			{ return 0; }
 static inline int
-perf_exclude_event(struct perf_event *event, struct pt_regs *regs)	{ return 0; }
+perf_exclude_event(struct perf_event *event, struct pt_regs *regs)		{ return 0; }
+
+#ifdef CONFIG_BPF_VERIFICATION_STUBS
+/*
+ * Callchain buffer declarations for BPF_MAP_TYPE_STACK_TRACE support.
+ * The actual stub implementations live in kernel/bpf/bpf_verification_stubs.c.
+ */
+extern int sysctl_perf_event_max_stack;
+extern int get_callchain_buffers(int max_stack);
+extern void put_callchain_buffers(void);
+extern struct perf_callchain_entry *get_callchain_entry(int *rctx);
+extern void put_callchain_entry(int rctx);
+extern struct perf_callchain_entry *
+get_perf_callchain(struct pt_regs *regs, bool kernel, bool user,
+		   u32 max_stack, bool crosstask, bool add_mark, u64 defer_cookie);
+#endif /* CONFIG_BPF_VERIFICATION_STUBS */
 
 #endif /* !CONFIG_PERF_EVENTS */
 
diff --git a/kernel/bpf/Kconfig b/kernel/bpf/Kconfig
index eb3de3573..c75ce4046 100644
--- a/kernel/bpf/Kconfig
+++ b/kernel/bpf/Kconfig
@@ -101,4 +101,22 @@ config BPF_LSM
 
 	  If you are unsure how to answer this question, answer N.
 
+config BPF_VERIFICATION_STUBS
+	bool "BPF program type stubs for verification-only kernels (UML)"
+	depends on BPF_SYSCALL
+	depends on !BPF_EVENTS
+	default y if UML
+	help
+	  Provides minimal verifier_ops/prog_ops for BPF program types that
+	  normally require CONFIG_BPF_EVENTS (tracing, kprobe, tracepoint,
+	  perf_event, raw_tracepoint) so the BPF verifier can accept these
+	  for static analysis (veristat).  Also provides STACK_TRACE map
+	  support via callchain buffer stubs.
+
+	  When CONFIG_SECURITY is also enabled, additionally provides
+	  BPF_PROG_TYPE_LSM stubs, BPF_MAP_TYPE_INODE_STORAGE, and
+	  FS kfuncs (bpf_get_file_xattr, etc.).
+
+	  Programs are never attached or executed.
+
 endmenu # "BPF subsystem"
diff --git a/kernel/bpf/Makefile b/kernel/bpf/Makefile
index 399007b67..26438fc45 100644
--- a/kernel/bpf/Makefile
+++ b/kernel/bpf/Makefile
@@ -12,7 +12,9 @@ obj-$(CONFIG_BPF_SYSCALL) += hashtab.o arraymap.o percpu_freelist.o bpf_lru_list
 obj-$(CONFIG_BPF_SYSCALL) += local_storage.o queue_stack_maps.o ringbuf.o bpf_insn_array.o
 obj-$(CONFIG_BPF_SYSCALL) += bpf_local_storage.o bpf_task_storage.o
 obj-$(CONFIG_BPF_SYSCALL) += fixups.o cfg.o states.o backtrack.o check_btf.o
-obj-${CONFIG_BPF_LSM}	  += bpf_inode_storage.o
+ifneq ($(filter y,$(CONFIG_BPF_LSM) $(CONFIG_BPF_VERIFICATION_STUBS)),)
+obj-$(CONFIG_BPF_SYSCALL) += bpf_inode_storage.o
+endif
 obj-$(CONFIG_BPF_SYSCALL) += disasm.o mprog.o
 obj-$(CONFIG_BPF_JIT) += trampoline.o
 obj-$(CONFIG_BPF_SYSCALL) += btf.o memalloc.o rqspinlock.o stream.o
@@ -27,7 +29,7 @@ obj-$(CONFIG_BPF_SYSCALL) += offload.o
 obj-$(CONFIG_BPF_SYSCALL) += net_namespace.o
 obj-$(CONFIG_BPF_SYSCALL) += tcx.o
 endif
-ifeq ($(CONFIG_PERF_EVENTS),y)
+ifneq ($(filter y,$(CONFIG_PERF_EVENTS) $(CONFIG_BPF_VERIFICATION_STUBS)),)
 obj-$(CONFIG_BPF_SYSCALL) += stackmap.o
 endif
 ifeq ($(CONFIG_CGROUPS),y)
@@ -68,6 +70,7 @@ ifeq ($(CONFIG_DMA_SHARED_BUFFER),y)
 obj-$(CONFIG_BPF_SYSCALL) += dmabuf_iter.o
 endif
 
+obj-$(CONFIG_BPF_VERIFICATION_STUBS) += bpf_verification_stubs.o
 CFLAGS_REMOVE_percpu_freelist.o = $(CC_FLAGS_FTRACE)
 CFLAGS_REMOVE_bpf_lru_list.o = $(CC_FLAGS_FTRACE)
 CFLAGS_REMOVE_queue_stack_maps.o = $(CC_FLAGS_FTRACE)
diff --git a/kernel/bpf/bpf_verification_stubs.c b/kernel/bpf/bpf_verification_stubs.c
new file mode 100644
index 000000000..c463bd439
--- /dev/null
+++ b/kernel/bpf/bpf_verification_stubs.c
@@ -0,0 +1,403 @@
+// SPDX-License-Identifier: GPL-2.0
+/*
+ * BPF program type stubs for verification-only kernels (e.g. UML)
+ *
+ * Provides minimal verifier_ops/prog_ops for BPF program types that
+ * normally require CONFIG_BPF_EVENTS or CONFIG_BPF_LSM so the verifier
+ * can accept BPF_PROG_LOAD for static analysis (veristat).  Programs
+ * are never attached or executed.
+ *
+ * Tracing stubs: KPROBE, TRACEPOINT, PERF_EVENT, RAW_TRACEPOINT,
+ *   RAW_TRACEPOINT_WRITABLE, TRACING + STACK_TRACE map support.
+ *
+ * LSM stubs (when CONFIG_SECURITY is set): BPF_PROG_TYPE_LSM,
+ *   BPF_MAP_TYPE_INODE_STORAGE, bpf_lsm_* BTF attach targets,
+ *   FS kfuncs (bpf_get_file_xattr, etc.).
+ */
+
+#include <linux/bpf.h>
+#include <linux/btf.h>
+#include <linux/filter.h>
+#include <linux/perf_event.h>
+
+/* --- Tracing program type stubs --- */
+
+extern const struct bpf_func_proto *
+bpf_base_func_proto(enum bpf_func_id func_id, const struct bpf_prog *prog);
+
+extern bool bpf_tracing_btf_ctx_access(int off, int size,
+	enum bpf_access_type type,
+	const struct bpf_prog *prog,
+	struct bpf_insn_access_aux *info);
+
+static const struct bpf_func_proto *
+stub_tracing_func_proto(enum bpf_func_id func_id, const struct bpf_prog *prog)
+{
+	return bpf_base_func_proto(func_id, prog);
+}
+
+static bool stub_tracing_is_valid_access(int off, int size,
+	enum bpf_access_type type,
+	const struct bpf_prog *prog,
+	struct bpf_insn_access_aux *info)
+{
+	return bpf_tracing_btf_ctx_access(off, size, type, prog, info);
+}
+
+#define DEFINE_STUB_OPS(name)						\
+const struct bpf_verifier_ops name##_verifier_ops = {			\
+	.get_func_proto  = stub_tracing_func_proto,			\
+	.is_valid_access = stub_tracing_is_valid_access,		\
+};									\
+const struct bpf_prog_ops name##_prog_ops = {};
+
+DEFINE_STUB_OPS(tracing)
+DEFINE_STUB_OPS(kprobe)
+DEFINE_STUB_OPS(tracepoint)
+DEFINE_STUB_OPS(perf_event)
+DEFINE_STUB_OPS(raw_tracepoint)
+DEFINE_STUB_OPS(raw_tracepoint_writable)
+
+/* --- Stack trace map support (callchain stubs) --- */
+
+int sysctl_perf_event_max_stack __read_mostly = PERF_MAX_STACK_DEPTH;
+
+int get_callchain_buffers(int max_stack)
+{
+	return 0;
+}
+
+void put_callchain_buffers(void)
+{
+}
+
+struct perf_callchain_entry *get_callchain_entry(int *rctx)
+{
+	WARN_ON_ONCE(1);
+	*rctx = -1;
+	return NULL;
+}
+
+void put_callchain_entry(int rctx)
+{
+}
+
+struct perf_callchain_entry *
+get_perf_callchain(struct pt_regs *regs, bool kernel, bool user,
+		   u32 max_stack, bool crosstask, bool add_mark, u64 defer_cookie)
+{
+	WARN_ON_ONCE(1);
+	return NULL;
+}
+
+/* --- LSM program type stubs (require CONFIG_SECURITY) --- */
+
+#ifdef CONFIG_SECURITY
+
+#include <linux/bpf_lsm.h>
+#include <linux/btf_ids.h>
+#include <linux/fs.h>
+
+/* Weak nop bpf_lsm_* functions — BTF attach targets for SEC("lsm/...") */
+#define LSM_HOOK(RET, DEFAULT, NAME, ...)	\
+__weak noinline RET bpf_lsm_##NAME(__VA_ARGS__)	\
+{						\
+	return DEFAULT;				\
+}
+
+#include <linux/lsm_hook_defs.h>
+#undef LSM_HOOK
+
+/* BTF ID sets for hook validation */
+
+#define LSM_HOOK(RET, DEFAULT, NAME, ...) BTF_ID(func, bpf_lsm_##NAME)
+BTF_SET_START(bpf_lsm_hooks)
+#include <linux/lsm_hook_defs.h>
+#undef LSM_HOOK
+BTF_SET_END(bpf_lsm_hooks)
+
+BTF_SET_START(bpf_lsm_disabled_hooks)
+BTF_ID(func, bpf_lsm_vm_enough_memory)
+BTF_ID(func, bpf_lsm_inode_need_killpriv)
+BTF_ID(func, bpf_lsm_inode_getsecurity)
+BTF_ID(func, bpf_lsm_inode_listsecurity)
+BTF_ID(func, bpf_lsm_inode_copy_up_xattr)
+BTF_ID(func, bpf_lsm_getselfattr)
+BTF_ID(func, bpf_lsm_getprocattr)
+BTF_ID(func, bpf_lsm_setprocattr)
+#ifdef CONFIG_KEYS
+BTF_ID(func, bpf_lsm_key_getsecurity)
+#endif
+#ifdef CONFIG_AUDIT
+BTF_ID(func, bpf_lsm_audit_rule_match)
+#endif
+BTF_ID(func, bpf_lsm_ismaclabel)
+BTF_ID(func, bpf_lsm_file_alloc_security)
+BTF_SET_END(bpf_lsm_disabled_hooks)
+
+BTF_SET_START(sleepable_lsm_hooks)
+BTF_ID(func, bpf_lsm_bpf)
+BTF_ID(func, bpf_lsm_bpf_map)
+BTF_ID(func, bpf_lsm_bpf_map_create)
+BTF_ID(func, bpf_lsm_bpf_map_free)
+BTF_ID(func, bpf_lsm_bpf_prog)
+BTF_ID(func, bpf_lsm_bpf_prog_load)
+BTF_ID(func, bpf_lsm_bpf_prog_free)
+BTF_ID(func, bpf_lsm_bpf_token_create)
+BTF_ID(func, bpf_lsm_bpf_token_free)
+BTF_ID(func, bpf_lsm_bpf_token_cmd)
+BTF_ID(func, bpf_lsm_bpf_token_capable)
+BTF_ID(func, bpf_lsm_bprm_check_security)
+BTF_ID(func, bpf_lsm_bprm_committed_creds)
+BTF_ID(func, bpf_lsm_bprm_committing_creds)
+BTF_ID(func, bpf_lsm_bprm_creds_for_exec)
+BTF_ID(func, bpf_lsm_bprm_creds_from_file)
+BTF_ID(func, bpf_lsm_capget)
+BTF_ID(func, bpf_lsm_capset)
+BTF_ID(func, bpf_lsm_cred_prepare)
+BTF_ID(func, bpf_lsm_file_ioctl)
+BTF_ID(func, bpf_lsm_file_lock)
+BTF_ID(func, bpf_lsm_file_open)
+BTF_ID(func, bpf_lsm_file_post_open)
+BTF_ID(func, bpf_lsm_file_receive)
+BTF_ID(func, bpf_lsm_inode_create)
+BTF_ID(func, bpf_lsm_inode_free_security)
+BTF_ID(func, bpf_lsm_inode_getattr)
+BTF_ID(func, bpf_lsm_inode_getxattr)
+BTF_ID(func, bpf_lsm_inode_mknod)
+BTF_ID(func, bpf_lsm_inode_need_killpriv)
+BTF_ID(func, bpf_lsm_inode_post_setxattr)
+BTF_ID(func, bpf_lsm_inode_post_removexattr)
+BTF_ID(func, bpf_lsm_inode_readlink)
+BTF_ID(func, bpf_lsm_inode_removexattr)
+BTF_ID(func, bpf_lsm_inode_rename)
+BTF_ID(func, bpf_lsm_inode_rmdir)
+BTF_ID(func, bpf_lsm_inode_setattr)
+BTF_ID(func, bpf_lsm_inode_setxattr)
+BTF_ID(func, bpf_lsm_inode_symlink)
+BTF_ID(func, bpf_lsm_inode_unlink)
+BTF_ID(func, bpf_lsm_kernel_module_request)
+BTF_ID(func, bpf_lsm_kernel_read_file)
+BTF_ID(func, bpf_lsm_kernfs_init_security)
+#ifdef CONFIG_SECURITY_PATH
+BTF_ID(func, bpf_lsm_path_unlink)
+BTF_ID(func, bpf_lsm_path_mkdir)
+BTF_ID(func, bpf_lsm_path_rmdir)
+BTF_ID(func, bpf_lsm_path_truncate)
+BTF_ID(func, bpf_lsm_path_symlink)
+BTF_ID(func, bpf_lsm_path_link)
+BTF_ID(func, bpf_lsm_path_rename)
+BTF_ID(func, bpf_lsm_path_chmod)
+BTF_ID(func, bpf_lsm_path_chown)
+#endif
+BTF_ID(func, bpf_lsm_mmap_file)
+BTF_ID(func, bpf_lsm_netlink_send)
+BTF_ID(func, bpf_lsm_path_notify)
+BTF_ID(func, bpf_lsm_release_secctx)
+BTF_ID(func, bpf_lsm_sb_alloc_security)
+BTF_ID(func, bpf_lsm_sb_eat_lsm_opts)
+BTF_ID(func, bpf_lsm_sb_kern_mount)
+BTF_ID(func, bpf_lsm_sb_mount)
+BTF_ID(func, bpf_lsm_sb_remount)
+BTF_ID(func, bpf_lsm_sb_set_mnt_opts)
+BTF_ID(func, bpf_lsm_sb_show_options)
+BTF_ID(func, bpf_lsm_sb_statfs)
+BTF_ID(func, bpf_lsm_sb_umount)
+BTF_ID(func, bpf_lsm_settime)
+#ifdef CONFIG_SECURITY_NETWORK
+BTF_ID(func, bpf_lsm_socket_accept)
+BTF_ID(func, bpf_lsm_socket_bind)
+BTF_ID(func, bpf_lsm_socket_connect)
+BTF_ID(func, bpf_lsm_socket_create)
+BTF_ID(func, bpf_lsm_socket_getpeername)
+BTF_ID(func, bpf_lsm_socket_getpeersec_dgram)
+BTF_ID(func, bpf_lsm_socket_getsockname)
+BTF_ID(func, bpf_lsm_socket_getsockopt)
+BTF_ID(func, bpf_lsm_socket_listen)
+BTF_ID(func, bpf_lsm_socket_post_create)
+BTF_ID(func, bpf_lsm_socket_recvmsg)
+BTF_ID(func, bpf_lsm_socket_sendmsg)
+BTF_ID(func, bpf_lsm_socket_shutdown)
+BTF_ID(func, bpf_lsm_socket_socketpair)
+#endif
+BTF_ID(func, bpf_lsm_syslog)
+BTF_ID(func, bpf_lsm_task_alloc)
+BTF_ID(func, bpf_lsm_task_prctl)
+BTF_ID(func, bpf_lsm_task_setscheduler)
