From 2001968fdc9183e2b7fc8ac7806ca51a63eef098 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 19 Jun 2026 13:56:53 -0700
Subject: [PATCH] um/x86: make synthetic BPF syscall wrappers patchable

UML provides synthetic __x64_sys_* functions so BPF selftests can
resolve x86-64 syscall-wrapper BTF attach targets.

Runtime fentry/fexit attachment also expects the target entry to have
a five-byte patchable slot that BPF trampoline code can replace with
a call.

Annotate the synthetic wrappers with patchable_function_entry(5, 0) and
move their prototypes into the UML syscall header so the definitions stay
clean under -Wmissing-prototypes.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 arch/x86/um/asm/syscall.h          | 13 +++++++++++++
 arch/x86/um/x64_syscall_wrappers.c | 22 +++++++++++-----------
 2 files changed, 24 insertions(+), 11 deletions(-)

diff --git a/arch/x86/um/asm/syscall.h b/arch/x86/um/asm/syscall.h
index d6208d0fad51..9a750e1f8a0b 100644
--- a/arch/x86/um/asm/syscall.h
+++ b/arch/x86/um/asm/syscall.h
@@ -11,6 +11,19 @@ typedef asmlinkage long (*sys_call_ptr_t)(unsigned long, unsigned long,
 
 extern const sys_call_ptr_t sys_call_table[];
 
+struct pt_regs;
+
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_getpgid(const struct pt_regs *regs);
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_nanosleep(const struct pt_regs *regs);
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_prctl(const struct pt_regs *regs);
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_prlimit64(const struct pt_regs *regs);
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_setdomainname(const struct pt_regs *regs);
+
 static inline int syscall_get_arch(struct task_struct *task)
 {
 #ifdef CONFIG_X86_32
diff --git a/arch/x86/um/x64_syscall_wrappers.c b/arch/x86/um/x64_syscall_wrappers.c
index 1d4160a2dca1..879fe3deaaa8 100644
--- a/arch/x86/um/x64_syscall_wrappers.c
+++ b/arch/x86/um/x64_syscall_wrappers.c
@@ -25,20 +25,17 @@
 #include <linux/time.h>
 #include <linux/resource.h>
 #include <asm/ptrace.h>
+#include <asm/syscall.h>
 #include <sysdep/ptrace.h>
 
-asmlinkage long __x64_sys_getpgid(const struct pt_regs *regs);
-asmlinkage long __x64_sys_nanosleep(const struct pt_regs *regs);
-asmlinkage long __x64_sys_prctl(const struct pt_regs *regs);
-asmlinkage long __x64_sys_prlimit64(const struct pt_regs *regs);
-asmlinkage long __x64_sys_setdomainname(const struct pt_regs *regs);
-
-asmlinkage long __x64_sys_getpgid(const struct pt_regs *regs)
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_getpgid(const struct pt_regs *regs)
 {
 	return sys_getpgid((pid_t)UPT_SYSCALL_ARG1(&regs->regs));
 }
 
-asmlinkage long __x64_sys_nanosleep(const struct pt_regs *regs)
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_nanosleep(const struct pt_regs *regs)
 {
 	return sys_nanosleep((struct __kernel_timespec __user *)
 			     UPT_SYSCALL_ARG1(&regs->regs),
@@ -46,7 +43,8 @@ asmlinkage long __x64_sys_nanosleep(const struct pt_regs *regs)
 			     UPT_SYSCALL_ARG2(&regs->regs));
 }
 
-asmlinkage long __x64_sys_prctl(const struct pt_regs *regs)
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_prctl(const struct pt_regs *regs)
 {
 	return sys_prctl((int)UPT_SYSCALL_ARG1(&regs->regs),
 			 UPT_SYSCALL_ARG2(&regs->regs),
@@ -55,7 +53,8 @@ asmlinkage long __x64_sys_prctl(const struct pt_regs *regs)
 			 UPT_SYSCALL_ARG5(&regs->regs));
 }
 
-asmlinkage long __x64_sys_prlimit64(const struct pt_regs *regs)
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_prlimit64(const struct pt_regs *regs)
 {
 	return sys_prlimit64((pid_t)UPT_SYSCALL_ARG1(&regs->regs),
 			     (unsigned int)UPT_SYSCALL_ARG2(&regs->regs),
@@ -64,7 +63,8 @@ asmlinkage long __x64_sys_prlimit64(const struct pt_regs *regs)
 			     (struct rlimit64 __user *)UPT_SYSCALL_ARG4(&regs->regs));
 }
 
-asmlinkage long __x64_sys_setdomainname(const struct pt_regs *regs)
+asmlinkage long __attribute__((patchable_function_entry(5, 0)))
+__x64_sys_setdomainname(const struct pt_regs *regs)
 {
 	return sys_setdomainname((char __user *)UPT_SYSCALL_ARG1(&regs->regs),
 				 (int)UPT_SYSCALL_ARG2(&regs->regs));
-- 
