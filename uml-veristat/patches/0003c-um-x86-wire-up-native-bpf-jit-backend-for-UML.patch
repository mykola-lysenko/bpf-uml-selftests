From 89d60a9a7f90bb53f40db32c17df47d2300d3f9e Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Fri, 24 Apr 2026 10:45:00 -0700
Subject: [PATCH] um/x86: wire up native x86 BPF JIT backend for UML

UML/x86-64 now selects HAVE_EBPF_JIT and boots with JIT enabled by
default, but the kernel still falls back to the weak stubs in
kernel/bpf/core.c. The real x86 JIT backend lives under arch/x86/net/,
and UML never links that directory. As a result,
bpf_jit_supports_kfunc_call() and related capability helpers keep
returning false, so kfunc-using programs fail with "JIT does not
support calling kernel function".

Wire arch/x86/net/ into the UML build and add the minimal UML/x86
compatibility glue needed for bpf_jit_comp.c to build:

- expose native x86 NOP and vsyscall definitions through UML asm/
  wrappers;
- provide the selector constants used by x86 speculation helpers;
- teach the JIT's pt_regs fixup table and exception handler to use UML's
  regs.gp[] layout;
- declare this_cpu_off and provide cpufeature fallback macros that UML's
  headers currently omit.

This gets the native x86 BPF JIT backend building under ARCH=um so its
strong symbols can override the generic stubs.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 arch/um/include/asm/cpufeature.h |  8 ++++++++
 arch/x86/Makefile.um             |  1 +
 arch/x86/net/bpf_jit_comp.c      | 28 +++++++++++++++++++++++++---
 arch/x86/um/asm/nops.h           |  7 +++++++
 arch/x86/um/asm/segment.h        | 15 +++++++++++++++
 arch/x86/um/asm/vsyscall.h       |  7 +++++++
 6 files changed, 63 insertions(+), 3 deletions(-)
 create mode 100644 arch/x86/um/asm/nops.h
 create mode 100644 arch/x86/um/asm/vsyscall.h

diff --git a/arch/um/include/asm/cpufeature.h b/arch/um/include/asm/cpufeature.h
index 4354f6984..b3489f0e3 100644
--- a/arch/um/include/asm/cpufeature.h
+++ b/arch/um/include/asm/cpufeature.h
@@ -33,6 +33,14 @@ extern const char * const x86_bug_flags[NBUGINTS*32];
 #define CHECK_BIT_IN_MASK_WORD(maskname, word, bit)	\
 	(((bit)>>5)==(word) && (1UL<<((bit)&31) & maskname##word ))
 
+#ifndef REQUIRED_MASK_BIT_SET
+#define REQUIRED_MASK_BIT_SET(bit) 0
+#endif
+
+#ifndef DISABLED_MASK_BIT_SET
+#define DISABLED_MASK_BIT_SET(bit) 0
+#endif
+
 #define cpu_has(c, bit)							\
 	 test_cpu_cap(c, bit)
 
diff --git a/arch/x86/Makefile.um b/arch/x86/Makefile.um
index c86cbd9cb..b8b5148f2 100644
--- a/arch/x86/Makefile.um
+++ b/arch/x86/Makefile.um
@@ -1,5 +1,6 @@
 # SPDX-License-Identifier: GPL-2.0
 core-y += arch/x86/crypto/
+core-y += arch/x86/net/
 
 #
 # Disable SSE and other FP/SIMD instructions to match normal x86
diff --git a/arch/x86/net/bpf_jit_comp.c b/arch/x86/net/bpf_jit_comp.c
index ea9e707e8..61ad7adda 100644
--- a/arch/x86/net/bpf_jit_comp.c
+++ b/arch/x86/net/bpf_jit_comp.c
@@ -11,15 +11,22 @@
 #include <linux/bitfield.h>
 #include <linux/bpf.h>
 #include <linux/memory.h>
+#include <linux/percpu.h>
 #include <linux/sort.h>
 #include <asm/extable.h>
 #include <asm/ftrace.h>
+#include <asm/nops.h>
 #include <asm/set_memory.h>
 #include <asm/nospec-branch.h>
 #include <asm/text-patching.h>
 #include <asm/unwind.h>
+#include <asm/vsyscall.h>
 #include <asm/cfi.h>
 
+#ifdef CONFIG_UML
+DECLARE_PER_CPU_CACHE_HOT(unsigned long, this_cpu_off);
+#endif
+
 static bool all_callee_regs_used[4] = {true, true, true, true};
 
 static u8 *emit_code(u8 *ptr, u32 bytes, unsigned int len)
@@ -197,6 +204,18 @@ static const int reg2hex[] = {
 };
 
 static const int reg2pt_regs[] = {
+#ifdef CONFIG_UML
+	[BPF_REG_0] = offsetof(struct pt_regs, regs.gp[HOST_AX]),
+	[BPF_REG_1] = offsetof(struct pt_regs, regs.gp[HOST_DI]),
+	[BPF_REG_2] = offsetof(struct pt_regs, regs.gp[HOST_SI]),
+	[BPF_REG_3] = offsetof(struct pt_regs, regs.gp[HOST_DX]),
+	[BPF_REG_4] = offsetof(struct pt_regs, regs.gp[HOST_CX]),
+	[BPF_REG_5] = offsetof(struct pt_regs, regs.gp[HOST_R8]),
+	[BPF_REG_6] = offsetof(struct pt_regs, regs.gp[HOST_BX]),
+	[BPF_REG_7] = offsetof(struct pt_regs, regs.gp[HOST_R13]),
+	[BPF_REG_8] = offsetof(struct pt_regs, regs.gp[HOST_R14]),
+	[BPF_REG_9] = offsetof(struct pt_regs, regs.gp[HOST_R15]),
+#else
 	[BPF_REG_0] = offsetof(struct pt_regs, ax),
 	[BPF_REG_1] = offsetof(struct pt_regs, di),
 	[BPF_REG_2] = offsetof(struct pt_regs, si),
@@ -207,6 +226,7 @@ static const int reg2pt_regs[] = {
 	[BPF_REG_7] = offsetof(struct pt_regs, r13),
 	[BPF_REG_8] = offsetof(struct pt_regs, r14),
 	[BPF_REG_9] = offsetof(struct pt_regs, r15),
+#endif
 };
 
 /*
@@ -1490,13 +1510,13 @@ bool ex_handler_bpf(const struct exception_table_entry *x, struct pt_regs *regs)
 		arena_reg = FIELD_GET(FIXUP_ARENA_REG_MASK, x->fixup);
 		off = FIELD_GET(DATA_ARENA_OFFSET_MASK, x->data);
 		addr = *(unsigned long *)((void *)regs + arena_reg) + off;
-		bpf_prog_report_arena_violation(is_write, addr, regs->ip);
+		bpf_prog_report_arena_violation(is_write, addr, PT_REGS_IP(regs));
 	}
 
 	/* jump over faulting load and clear dest register */
 	if (reg != DONT_CLEAR)
 		*(unsigned long *)((void *)regs + reg) = 0;
-	regs->ip += insn_len;
+	PT_REGS_IP(regs) += insn_len;
 
 	return true;
 }
diff --git a/arch/x86/um/asm/nops.h b/arch/x86/um/asm/nops.h
new file mode 100644
index 000000000..cbd8aadb9
--- /dev/null
+++ b/arch/x86/um/asm/nops.h
@@ -0,0 +1,7 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef __UM_X86_NOPS_H
+#define __UM_X86_NOPS_H
+
+#include "../../include/asm/nops.h"
+
+#endif
diff --git a/arch/x86/um/asm/segment.h b/arch/x86/um/asm/segment.h
index 2ef507bc6..138fdde0e 100644
--- a/arch/x86/um/asm/segment.h
+++ b/arch/x86/um/asm/segment.h
@@ -8,4 +8,19 @@ extern int host_gdt_entry_tls_min;
 #define GDT_ENTRY_TLS_MIN host_gdt_entry_tls_min
 #define GDT_ENTRY_TLS_MAX (GDT_ENTRY_TLS_MIN + GDT_ENTRY_TLS_ENTRIES - 1)
 
+#ifdef CONFIG_X86_64
+#define GDT_ENTRY_KERNEL32_CS		1
+#define GDT_ENTRY_KERNEL_CS		2
+#define GDT_ENTRY_KERNEL_DS		3
+#define GDT_ENTRY_DEFAULT_USER32_CS	4
+#define GDT_ENTRY_DEFAULT_USER_DS	5
+#define GDT_ENTRY_DEFAULT_USER_CS	6
+#define __KERNEL32_CS			(GDT_ENTRY_KERNEL32_CS * 8)
+#define __KERNEL_CS			(GDT_ENTRY_KERNEL_CS * 8)
+#define __KERNEL_DS			(GDT_ENTRY_KERNEL_DS * 8)
+#define __USER32_CS			(GDT_ENTRY_DEFAULT_USER32_CS * 8 + 3)
+#define __USER_DS			(GDT_ENTRY_DEFAULT_USER_DS * 8 + 3)
+#define __USER_CS			(GDT_ENTRY_DEFAULT_USER_CS * 8 + 3)
+#endif
+
 #endif
diff --git a/arch/x86/um/asm/vsyscall.h b/arch/x86/um/asm/vsyscall.h
new file mode 100644
index 000000000..c08303d8b
--- /dev/null
+++ b/arch/x86/um/asm/vsyscall.h
@@ -0,0 +1,7 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef __UM_X86_VSYSCALL_H
+#define __UM_X86_VSYSCALL_H
+
+#include "../../include/uapi/asm/vsyscall.h"
+
+#endif
