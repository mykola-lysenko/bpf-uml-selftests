From 2f291554a13f03efdfeca84b0897936eeb644b12 Mon Sep 17 00:00:00 2001
From: uml-veristat build <uml-veristat@build>
Date: Tue, 21 Apr 2026 19:01:27 -0400
Subject: [PATCH 5/5] bpf: extend BPF_TRACING_STUBS with STACK_TRACE map and
 callchain stubs

Without CONFIG_PERF_EVENTS, BPF_MAP_TYPE_STACK_TRACE is not registered
and bpf_get_stackid()/bpf_get_stack() helpers are not available.  This
causes veristat to fail with -EINVAL when processing programs that use
stack trace maps (pyperf*, strobemeta*, stacktrace_*).

Extend the existing CONFIG_BPF_TRACING_STUBS infrastructure (introduced
for UML) to also cover stack trace support:

1. kernel/bpf/stackmap.c: compile when CONFIG_BPF_TRACING_STUBS is set
   in addition to CONFIG_PERF_EVENTS.  Wrap the perf_event-specific
   bpf_get_stackid_pe/bpf_get_stack_pe functions in #ifdef CONFIG_PERF_EVENTS
   since they reference struct perf_event internals.

2. kernel/bpf/bpf_tracing_stubs.c: add stub implementations for the
   callchain buffer API (get_callchain_buffers, put_callchain_buffers,
   get_callchain_entry, put_callchain_entry, get_perf_callchain) and
   the sysctl_perf_event_max_stack variable.  These are never called
   during verifier-only operation (veristat never executes programs),
   so WARN_ON_ONCE stubs are sufficient.

3. include/linux/perf_event.h: declare the stub symbols under

4. include/linux/bpf_types.h: register BPF_MAP_TYPE_STACK_TRACE when
   CONFIG_BPF_TRACING_STUBS is set, mirroring the CONFIG_PERF_EVENTS guard.

Also enable CONFIG_CGROUP_BPF=y and CONFIG_XDP_SOCKETS=y in the UML
defconfig to fix EINVAL failures for cgroup storage maps and XSK maps.

Tested: veristat success rate improves from 1477 to 1597 programs
(+120, +8.1%) on the BPF selftests suite running under UML.

Signed-off-by: Mykola Lysenko <mykolal@fb.com>
---
 include/linux/bpf_types.h      | 15 +--------
 include/linux/perf_event.h     | 17 +++++++++-
 kernel/bpf/Makefile            |  3 +-
 kernel/bpf/bpf_tracing_stubs.c | 61 ++++++++++++++++++++++++++++++++++
 kernel/bpf/stackmap.c          |  2 ++
 5 files changed, 82 insertions(+), 16 deletions(-)

diff --git a/include/linux/bpf_types.h b/include/linux/bpf_types.h
index f470fe244..e170a0683 100644
--- a/include/linux/bpf_types.h
+++ b/include/linux/bpf_types.h
@@ -104,19 +104,6 @@ BPF_MAP_TYPE(BPF_MAP_TYPE_PERF_EVENT_ARRAY, perf_event_array_map_ops)
 #ifdef CONFIG_CGROUPS
 BPF_MAP_TYPE(BPF_MAP_TYPE_CGROUP_ARRAY, cgroup_array_map_ops)
 BPF_MAP_TYPE(BPF_MAP_TYPE_CGRP_STORAGE, cgrp_storage_map_ops)
-#elif defined(CONFIG_BPF_TRACING_STUBS)
-BPF_PROG_TYPE(BPF_PROG_TYPE_KPROBE, kprobe,
-	      bpf_user_pt_regs_t, struct pt_regs)
-BPF_PROG_TYPE(BPF_PROG_TYPE_TRACEPOINT, tracepoint,
-	      __u64, u64)
-BPF_PROG_TYPE(BPF_PROG_TYPE_PERF_EVENT, perf_event,
-	      struct bpf_perf_event_data, struct bpf_perf_event_data_kern)
-BPF_PROG_TYPE(BPF_PROG_TYPE_RAW_TRACEPOINT, raw_tracepoint,
-	      struct bpf_raw_tracepoint_args, u64)
-BPF_PROG_TYPE(BPF_PROG_TYPE_RAW_TRACEPOINT_WRITABLE, raw_tracepoint_writable,
-	      struct bpf_raw_tracepoint_args, u64)
-BPF_PROG_TYPE(BPF_PROG_TYPE_TRACING, tracing,
-	      void *, void *)
 #endif
 #ifdef CONFIG_CGROUP_BPF
 BPF_MAP_TYPE(BPF_MAP_TYPE_CGROUP_STORAGE, cgroup_storage_map_ops)
@@ -127,7 +114,7 @@ BPF_MAP_TYPE(BPF_MAP_TYPE_PERCPU_HASH, htab_percpu_map_ops)
 BPF_MAP_TYPE(BPF_MAP_TYPE_LRU_HASH, htab_lru_map_ops)
 BPF_MAP_TYPE(BPF_MAP_TYPE_LRU_PERCPU_HASH, htab_lru_percpu_map_ops)
 BPF_MAP_TYPE(BPF_MAP_TYPE_LPM_TRIE, trie_map_ops)
-#ifdef CONFIG_PERF_EVENTS
+#if defined(CONFIG_PERF_EVENTS) || defined(CONFIG_BPF_TRACING_STUBS)
 BPF_MAP_TYPE(BPF_MAP_TYPE_STACK_TRACE, stack_trace_map_ops)
 #endif
 BPF_MAP_TYPE(BPF_MAP_TYPE_ARRAY_OF_MAPS, array_of_maps_map_ops)
diff --git a/include/linux/perf_event.h b/include/linux/perf_event.h
index 48d851fbd..9bb5afce4 100644
--- a/include/linux/perf_event.h
+++ b/include/linux/perf_event.h
@@ -2021,7 +2021,22 @@ perf_event_period(struct perf_event *event, u64 value)			{ return -EINVAL; }
 static inline u64
 perf_event_pause(struct perf_event *event, bool reset)			{ return 0; }
 static inline int
-perf_exclude_event(struct perf_event *event, struct pt_regs *regs)	{ return 0; }
+perf_exclude_event(struct perf_event *event, struct pt_regs *regs)		{ return 0; }
+
+#ifdef CONFIG_BPF_TRACING_STUBS
+/*
+ * Callchain buffer declarations for BPF_MAP_TYPE_STACK_TRACE support.
+ * The actual stub implementations live in kernel/bpf/bpf_tracing_stubs.c.
+ */
+extern int sysctl_perf_event_max_stack;
+extern int get_callchain_buffers(int max_stack);
+extern void put_callchain_buffers(void);
+extern struct perf_callchain_entry *get_callchain_entry(int *rctx);
+extern void put_callchain_entry(int rctx);
+extern struct perf_callchain_entry *
+get_perf_callchain(struct pt_regs *regs, bool kernel, bool user,
+		   u32 max_stack, bool crosstask, bool add_mark, u64 defer_cookie);
+#endif /* CONFIG_BPF_TRACING_STUBS */
 
 #endif /* !CONFIG_PERF_EVENTS */
 
diff --git a/kernel/bpf/Makefile b/kernel/bpf/Makefile
index 401c3c579..e3720b04b 100644
--- a/kernel/bpf/Makefile
+++ b/kernel/bpf/Makefile
@@ -27,7 +27,8 @@ obj-$(CONFIG_BPF_SYSCALL) += offload.o
 obj-$(CONFIG_BPF_SYSCALL) += net_namespace.o
 obj-$(CONFIG_BPF_SYSCALL) += tcx.o
 endif
-ifeq ($(CONFIG_PERF_EVENTS),y)
+ifeq ($(CONFIG_PERF_EVENTS)$(CONFIG_BPF_TRACING_STUBS),)
+else
 obj-$(CONFIG_BPF_SYSCALL) += stackmap.o
 endif
 ifeq ($(CONFIG_CGROUPS),y)
diff --git a/kernel/bpf/bpf_tracing_stubs.c b/kernel/bpf/bpf_tracing_stubs.c
index b63e93f6d..0b2015805 100644
--- a/kernel/bpf/bpf_tracing_stubs.c
+++ b/kernel/bpf/bpf_tracing_stubs.c
@@ -11,10 +11,16 @@
  * accept BPF_PROG_LOAD -- programs are never attached or executed.
  * This file provides minimal verifier_ops/prog_ops for the tracing-family
  * program types so the verifier can run normally.
+ *
+ * It also provides stubs for the perf callchain buffer infrastructure so
+ * that BPF_MAP_TYPE_STACK_TRACE maps can be created and verified without
+ * CONFIG_PERF_EVENTS.  The stubs are safe for map allocation (which is all
+ * veristat exercises); they must never be called at program execution time.
  */
 
 #include <linux/bpf.h>
 #include <linux/filter.h>
+#include <linux/perf_event.h>
 
 extern const struct bpf_func_proto *
 bpf_base_func_proto(enum bpf_func_id func_id, const struct bpf_prog *prog);
@@ -79,3 +85,58 @@ const struct bpf_verifier_ops raw_tracepoint_writable_verifier_ops = {
 .is_valid_access = stub_tracing_is_valid_access,
 };
 const struct bpf_prog_ops raw_tracepoint_writable_prog_ops = {};
+
+/*
+ * Callchain buffer stubs for BPF_MAP_TYPE_STACK_TRACE
+ *
+ * stackmap.c calls get_callchain_buffers() during map_alloc to reserve
+ * per-cpu callchain buffers, and put_callchain_buffers() during map_free.
+ * For veristat we only create/destroy maps; programs are never executed so
+ * get_callchain_entry()/put_callchain_entry() are never reached.
+ *
+ * sysctl_perf_event_max_stack is used by stackmap.c to validate the
+ * requested stack depth at map creation time.
+ */
+int sysctl_perf_event_max_stack __read_mostly = PERF_MAX_STACK_DEPTH;
+
+int get_callchain_buffers(int max_stack)
+{
+	/* No real per-cpu buffers needed; just allow map creation. */
+	return 0;
+}
+
+void put_callchain_buffers(void)
+{
+	/* No-op: nothing was allocated by get_callchain_buffers(). */
+}
+
+/*
+ * get_callchain_entry() and put_callchain_entry() are called only during
+ * BPF program execution (inside bpf_get_stackid / bpf_get_stack helpers).
+ * veristat never executes programs, so these should never be reached.
+ * Provide link-time stubs to satisfy the linker.
+ */
+struct perf_callchain_entry *get_callchain_entry(int *rctx)
+{
+	WARN_ON_ONCE(1);
+	*rctx = -1;
+	return NULL;
+}
+
+void put_callchain_entry(int rctx)
+{
+	/* Should never be called in veristat context. */
+}
+
+/*
+ * get_perf_callchain() is called by bpf_get_stackid() helper at BPF program
+ * execution time.  veristat never executes programs, so this should never
+ * be reached.  Provide a link-time stub.
+ */
+struct perf_callchain_entry *
+get_perf_callchain(struct pt_regs *regs, bool kernel, bool user,
+   u32 max_stack, bool crosstask, bool add_mark, u64 defer_cookie)
+{
+WARN_ON_ONCE(1);
+return NULL;
+}
diff --git a/kernel/bpf/stackmap.c b/kernel/bpf/stackmap.c
index da3d328f5..ee4e412f0 100644
--- a/kernel/bpf/stackmap.c
+++ b/kernel/bpf/stackmap.c
@@ -365,6 +365,7 @@ static __u64 count_kernel_ip(struct perf_callchain_entry *trace)
 	return nr_kernel;
 }
 
+#ifdef CONFIG_PERF_EVENTS
 BPF_CALL_3(bpf_get_stackid_pe, struct bpf_perf_event_data_kern *, ctx,
 	   struct bpf_map *, map, u64, flags)
 {
@@ -656,6 +657,7 @@ const struct bpf_func_proto bpf_get_stack_proto_pe = {
 	.arg3_type	= ARG_CONST_SIZE_OR_ZERO,
 	.arg4_type	= ARG_ANYTHING,
 };
+#endif /* CONFIG_PERF_EVENTS */
 
 /* Called from eBPF program */
 static void *stack_map_lookup_elem(struct bpf_map *map, void *key)
-- 
