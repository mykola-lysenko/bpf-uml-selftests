From b718e4b15381a167d36bcbc3c952be288cba7e43 Mon Sep 17 00:00:00 2001
From: uml-veristat build <uml-veristat@build>
Date: Tue, 21 Apr 2026 00:29:15 -0400
Subject: [PATCH 3/5] um/x86: fix UML boot and enable BPF_JIT for struct_ops
 support

Two fixes to make BPF work better in UML:

1. arch/um/kernel/skas/Makefile: Remove -Wl,-n from STUB_EXE_LDFLAGS.
   The -Wl,-n flag creates a non-demand-paged output, which causes the
   stub binary to have LOAD segments with Align=0x8 instead of Align=0x1000.
   UML requires page-aligned LOAD segments in the stub binary to properly
   map it into the guest address space. Without this fix, UML fails to boot
   with 'mmap stub_exe' errors.

2. arch/x86/um/Kconfig: Add 'select HAVE_EBPF_JIT if 64BIT' to UML_X86.
   UML on x86-64 can use the x86-64 BPF JIT. Without HAVE_EBPF_JIT,
   CONFIG_BPF_JIT cannot be enabled, and register_bpf_struct_ops() becomes
   a no-op (it returns -EOPNOTSUPP when JIT is disabled). This means all
   struct_ops BPF programs fail to load. With HAVE_EBPF_JIT selected,
   CONFIG_BPF_JIT=y works and struct_ops programs can be verified.

Signed-off-by: Manus AI <manus@example.com>
---
 arch/um/kernel/skas/Makefile | 2 +-
 arch/x86/um/Kconfig          | 1 +
 2 files changed, 2 insertions(+), 1 deletion(-)

diff --git a/arch/um/kernel/skas/Makefile b/arch/um/kernel/skas/Makefile
index 3384be426..b2cb6fd48 100644
--- a/arch/um/kernel/skas/Makefile
+++ b/arch/um/kernel/skas/Makefile
@@ -27,7 +27,7 @@ quiet_cmd_stub_exe = STUB_EXE $@
 			   $(filter-out $(UM_GPROF_OPT) $(UM_GCOV_OPT),$(KBUILD_CFLAGS)) $(STUB_EXE_LDFLAGS) \
 			   $(filter %.o,$^)
 
-STUB_EXE_LDFLAGS = -Wl,-n -static
+STUB_EXE_LDFLAGS = -static
 
 targets += stub_exe.dbg stub_exe $(stub_exe_objs-y)
 
diff --git a/arch/x86/um/Kconfig b/arch/x86/um/Kconfig
index 44b12e45f..e3f2ec1fa 100644
--- a/arch/x86/um/Kconfig
+++ b/arch/x86/um/Kconfig
@@ -13,6 +13,7 @@ config UML_X86
 	select ARCH_USE_QUEUED_SPINLOCKS
 	select DCACHE_WORD_ACCESS
 	select HAVE_EFFICIENT_UNALIGNED_ACCESS
+	select HAVE_EBPF_JIT if 64BIT
 	select UML_SUBARCH_SUPPORTS_SMP if X86_CX8
 
 config 64BIT
