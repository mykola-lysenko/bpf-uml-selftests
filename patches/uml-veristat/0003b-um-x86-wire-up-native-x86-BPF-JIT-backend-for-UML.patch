From d9d95e138eb1950cf157e0775a4d149509065e85 Mon Sep 17 00:00:00 2001
From: Mykola Lysenko <mykolal@meta.com>
Date: Sat, 11 Jul 2026 09:43:52 -0700
Subject: [PATCH] um/x86: wire up the native x86 BPF JIT backend for UML

UML/x86-64 now selects HAVE_EBPF_JIT and boots with JIT enabled by
default, but the kernel still falls back to the weak stubs in
kernel/bpf/core.c. The real x86 JIT backend lives under arch/x86/net/,
and UML does not link that directory.

Wire arch/x86/net/ into the UML build and add the minimal UML/x86
compatibility glue needed for bpf_jit_comp.c to build and link under
ARCH=um. This includes pt_regs layout handling, native x86 asm wrapper
headers, selector constants, and UML-local verification-only shims for
text patching, NOP, CFI, BHB, and per-cpu symbols that the native
backend references.

The UML compatibility shims are limited to load-time verifier and JIT
analysis; they do not provide runtime text patching semantics. Use direct
memcpy-based text copies on UML to avoid routing final JIT image
installation through UML's warning-only text_poke() stub.

This lets the native x86 BPF JIT backend provide the strong capability
symbols used by kfunc and arena verification without leaving an
intermediate unbuildable UML kernel state.

Kconfig-wise, select HAVE_EBPF_JIT and ARCH_WANT_DEFAULT_BPF_JIT for
64-bit UML so CONFIG_BPF_JIT can be enabled and defaults on, matching
native x86-64; without HAVE_EBPF_JIT, register_bpf_struct_ops()
returns -EOPNOTSUPP and all struct_ops programs fail to load.

The backend also needs far-call support: UML kernel text sits at
0x60000000 while BPF JIT images live in host mmap space, so
trampoline and kfunc calls can exceed the +/-2GB direct-call range.
Emit indirect calls through a scratch register when the target is
out of range instead of failing the JIT.

Signed-off-by: Mykola Lysenko <mykolal@meta.com>
---
 arch/um/include/asm/cpufeature.h |   8 ++
 arch/x86/Makefile.um             |   1 +
 arch/x86/net/bpf_jit_comp.c      | 175 +++++++++++++++++++++++++++++--
 arch/x86/um/Kconfig              |   2 +
 arch/x86/um/asm/nops.h           |   7 ++
 arch/x86/um/asm/segment.h        |  15 +++
 arch/x86/um/asm/vsyscall.h       |   7 ++
 7 files changed, 209 insertions(+), 6 deletions(-)
 create mode 100644 arch/x86/um/asm/nops.h
 create mode 100644 arch/x86/um/asm/vsyscall.h

diff --git a/arch/um/include/asm/cpufeature.h b/arch/um/include/asm/cpufeature.h
index 4354f6984..b3489f0e3 100644
--- a/arch/um/include/asm/cpufeature.h
+++ b/arch/um/include/asm/cpufeature.h
@@ -33,6 +33,14 @@ extern const char * const x86_bug_flags[NBUGINTS*32];
 #define CHECK_BIT_IN_MASK_WORD(maskname, word, bit)	\
 	(((bit)>>5)==(word) && (1UL<<((bit)&31) & maskname##word ))
 
+#ifndef REQUIRED_MASK_BIT_SET
+#define REQUIRED_MASK_BIT_SET(bit) 0
+#endif
+
+#ifndef DISABLED_MASK_BIT_SET
+#define DISABLED_MASK_BIT_SET(bit) 0
+#endif
+
 #define cpu_has(c, bit)							\
 	 test_cpu_cap(c, bit)
 
diff --git a/arch/x86/Makefile.um b/arch/x86/Makefile.um
index 9adecd656..f65289362 100644
--- a/arch/x86/Makefile.um
+++ b/arch/x86/Makefile.um
@@ -1,5 +1,6 @@
 # SPDX-License-Identifier: GPL-2.0
 core-y += arch/x86/crypto/
+core-y += arch/x86/net/
 
 #
 # Disable SSE and other FP/SIMD instructions to match normal x86
diff --git a/arch/x86/net/bpf_jit_comp.c b/arch/x86/net/bpf_jit_comp.c
index de7515ea1..84f12498a 100644
--- a/arch/x86/net/bpf_jit_comp.c
+++ b/arch/x86/net/bpf_jit_comp.c
@@ -12,15 +12,68 @@
 #include <linux/bpf.h>
 #include <linux/bpf_verifier.h>
 #include <linux/memory.h>
+#include <linux/percpu.h>
 #include <linux/sort.h>
 #include <asm/extable.h>
 #include <asm/ftrace.h>
+#include <asm/nops.h>
 #include <asm/set_memory.h>
 #include <asm/nospec-branch.h>
 #include <asm/text-patching.h>
 #include <asm/unwind.h>
+#include <asm/vsyscall.h>
 #include <asm/cfi.h>
 
+#ifdef CONFIG_UML
+static const unsigned char x86_nop1[] = { BYTES_NOP1 };
+static const unsigned char x86_nop2[] = { BYTES_NOP2 };
+static const unsigned char x86_nop3[] = { BYTES_NOP3 };
+static const unsigned char x86_nop4[] = { BYTES_NOP4 };
+static const unsigned char x86_nop5[] = { BYTES_NOP5 };
+static const unsigned char x86_nop6[] = { BYTES_NOP6 };
+static const unsigned char x86_nop7[] = { BYTES_NOP7 };
+static const unsigned char x86_nop8[] = { BYTES_NOP8 };
+#ifdef CONFIG_X86_64
+static const unsigned char x86_nop9[] = { BYTES_NOP9 };
+static const unsigned char x86_nop10[] = { BYTES_NOP10 };
+static const unsigned char x86_nop11[] = { BYTES_NOP11 };
+#endif
+
+const unsigned char * const x86_nops[ASM_NOP_MAX + 1] = {
+	NULL,
+	x86_nop1,
+	x86_nop2,
+	x86_nop3,
+	x86_nop4,
+	x86_nop5,
+	x86_nop6,
+	x86_nop7,
+	x86_nop8,
+#ifdef CONFIG_X86_64
+	x86_nop9,
+	x86_nop10,
+	x86_nop11,
+#endif
+};
+
+enum cfi_mode cfi_mode = CFI_OFF;
+unsigned long this_cpu_off;
+
+void clear_bhb_loop(void)
+{
+}
+
+void *text_poke_set(void *addr, int c, size_t len)
+{
+	return memset(addr, c, len);
+}
+
+void smp_text_poke_single(void *addr, const void *opcode, size_t len, const void *emulate)
+{
+	memcpy(addr, opcode, len);
+}
+#endif
+
 static bool all_callee_regs_used[4] = {true, true, true, true};
 
 static u8 *emit_code(u8 *ptr, u32 bytes, unsigned int len)
@@ -198,6 +251,18 @@ static const int reg2hex[] = {
 };
 
 static const int reg2pt_regs[] = {
+#ifdef CONFIG_UML
+	[BPF_REG_0] = offsetof(struct pt_regs, regs.gp[HOST_AX]),
+	[BPF_REG_1] = offsetof(struct pt_regs, regs.gp[HOST_DI]),
+	[BPF_REG_2] = offsetof(struct pt_regs, regs.gp[HOST_SI]),
+	[BPF_REG_3] = offsetof(struct pt_regs, regs.gp[HOST_DX]),
+	[BPF_REG_4] = offsetof(struct pt_regs, regs.gp[HOST_CX]),
+	[BPF_REG_5] = offsetof(struct pt_regs, regs.gp[HOST_R8]),
+	[BPF_REG_6] = offsetof(struct pt_regs, regs.gp[HOST_BX]),
+	[BPF_REG_7] = offsetof(struct pt_regs, regs.gp[HOST_R13]),
+	[BPF_REG_8] = offsetof(struct pt_regs, regs.gp[HOST_R14]),
+	[BPF_REG_9] = offsetof(struct pt_regs, regs.gp[HOST_R15]),
+#else
 	[BPF_REG_0] = offsetof(struct pt_regs, ax),
 	[BPF_REG_1] = offsetof(struct pt_regs, di),
 	[BPF_REG_2] = offsetof(struct pt_regs, si),
@@ -208,6 +273,7 @@ static const int reg2pt_regs[] = {
 	[BPF_REG_7] = offsetof(struct pt_regs, r13),
 	[BPF_REG_8] = offsetof(struct pt_regs, r14),
 	[BPF_REG_9] = offsetof(struct pt_regs, r15),
+#endif
 };
 
 /*
@@ -444,6 +510,7 @@ static void emit_nops(u8 **pprog, int len)
  */
 static int emit_call(u8 **prog, void *func, void *ip);
 
+#ifndef CONFIG_UML
 static void emit_fineibt(u8 **pprog, u8 *ip, u32 hash, int arity)
 {
 	u8 *prog = *pprog;
@@ -474,11 +541,15 @@ static void emit_kcfi(u8 **pprog, u32 hash)
 
 	*pprog = prog;
 }
+#endif
 
 static void emit_cfi(u8 **pprog, u8 *ip, u32 hash, int arity)
 {
 	u8 *prog = *pprog;
 
+#ifdef CONFIG_UML
+	EMIT_ENDBR();
+#else
 	switch (cfi_mode) {
 	case CFI_FINEIBT:
 		emit_fineibt(&prog, ip, hash, arity);
@@ -492,6 +563,7 @@ static void emit_cfi(u8 **pprog, u8 *ip, u32 hash, int arity)
 		EMIT_ENDBR();
 		break;
 	}
+#endif
 
 	*pprog = prog;
 }
@@ -700,6 +772,11 @@ static void emit_indirect_jump(u8 **pprog, int bpf_reg, u8 *ip)
 	int reg = reg2hex[bpf_reg];
 	bool ereg = is_ereg(bpf_reg);
 
+#ifdef CONFIG_UML
+	__emit_indirect_jump(&prog, reg, ereg);
+	if (IS_ENABLED(CONFIG_MITIGATION_RETPOLINE) || IS_ENABLED(CONFIG_MITIGATION_SLS))
+		EMIT1(0xCC);
+#else
 	if (cpu_feature_enabled(X86_FEATURE_INDIRECT_THUNK_ITS)) {
 		OPTIMIZER_HIDE_VAR(reg);
 		emit_jump(&prog, its_static_thunk(reg + 8*ereg), ip);
@@ -717,6 +794,7 @@ static void emit_indirect_jump(u8 **pprog, int bpf_reg, u8 *ip)
 		if (IS_ENABLED(CONFIG_MITIGATION_RETPOLINE) || IS_ENABLED(CONFIG_MITIGATION_SLS))
 			EMIT1(0xCC);		/* int3 */
 	}
+#endif
 
 	*pprog = prog;
 }
@@ -1001,6 +1079,43 @@ static void emit_mov_imm64(u8 **pprog, u32 dst_reg,
 	*pprog = prog;
 }
 
+#ifdef CONFIG_UML
+static void emit_indirect_call(u8 **pprog, void *func)
+{
+	unsigned long addr = (unsigned long)func;
+	u8 *prog = *pprog;
+	int reg = reg2hex[AUX_REG];
+
+	EMIT2(add_1mod(0x48, AUX_REG), add_1reg(0xB8, AUX_REG));
+	EMIT((u32)addr, 4);
+	EMIT(addr >> 32, 4);
+	if (is_ereg(AUX_REG))
+		EMIT1(0x41);
+	EMIT2(0xFF, 0xD0 + reg);
+
+	*pprog = prog;
+}
+
+static int emit_call_or_indirect(u8 **pprog, void *func, void *ip)
+{
+	emit_indirect_call(pprog, func);
+	return 0;
+}
+
+static int emit_direct_call_or_placeholder(u8 **pprog, void *func, void *ip)
+{
+	u8 *prog = *pprog;
+
+	if (!func) {
+		EMIT1_off32(0xE8, 0);
+		*pprog = prog;
+		return 0;
+	}
+
+	return emit_call(pprog, func, ip);
+}
+#endif
+
 static void emit_mov_reg(u8 **pprog, bool is64, u32 dst_reg, u32 src_reg)
 {
 	u8 *prog = *pprog;
@@ -1519,13 +1634,13 @@ bool ex_handler_bpf(const struct exception_table_entry *x, struct pt_regs *regs)
 		arena_reg = FIELD_GET(FIXUP_ARENA_REG_MASK, x->fixup);
 		off = FIELD_GET(DATA_ARENA_OFFSET_MASK, x->data);
 		addr = *(unsigned long *)((void *)regs + arena_reg) + off;
-		bpf_prog_report_arena_violation(is_write, addr, regs->ip);
+		bpf_prog_report_arena_violation(is_write, addr, PT_REGS_IP(regs));
 	}
 
 	/* jump over faulting load and clear dest register */
 	if (reg != DONT_CLEAR)
 		*(unsigned long *)((void *)regs + reg) = 0;
-	regs->ip += insn_len;
+	PT_REGS_IP(regs) += insn_len;
 
 	return true;
 }
@@ -1642,6 +1757,11 @@ static int emit_spectre_bhb_barrier(u8 **pprog, u8 *ip,
 	u8 *prog = *pprog;
 	u8 *func;
 
+#ifdef CONFIG_UML
+	*pprog = prog;
+	return 0;
+#endif
+
 	if (cpu_feature_enabled(X86_FEATURE_CLEAR_BHB_LOOP)) {
 		/* The clearing sequence clobbers eax and ecx. */
 		EMIT1(0x50); /* push rax */
@@ -1679,7 +1799,8 @@ static int emit_spectre_bhb_barrier(u8 **pprog, u8 *ip,
 }
 
 static int do_jit(struct bpf_verifier_env *env, struct bpf_prog *bpf_prog, int *addrs, u8 *image,
-		  u8 *rw_image, int oldproglen, struct jit_context *ctx, bool jmp_padding)
+		  u8 *rw_image, int oldproglen, struct jit_context *ctx, bool jmp_padding,
+		  bool extra_pass)
 {
 	bool tail_call_reachable = bpf_prog->aux->tail_call_reachable;
 	struct bpf_insn *insn = bpf_prog->insnsi;
@@ -2576,19 +2697,43 @@ st:			insn_off = insn->off;
 
 			/* call */
 		case BPF_JMP | BPF_CALL: {
-			func = (u8 *) __bpf_call_base + imm32;
+#ifdef CONFIG_UML
+			bool func_addr_fixed;
+			u64 func_addr;
+
+			err = bpf_jit_get_func_addr(bpf_prog, insn, extra_pass,
+						    &func_addr, &func_addr_fixed);
+			if (err < 0)
+				return err;
+			func = (u8 *)func_addr;
+#else
+			func = (u8 *)__bpf_call_base + imm32;
+#endif
 			if (src_reg == BPF_PSEUDO_CALL && tail_call_reachable) {
 				LOAD_TAIL_CALL_CNT_PTR(stack_depth);
 				ip += 7;
 			}
+#ifdef CONFIG_UML
+			if (!func && func_addr_fixed)
+				return -EINVAL;
+#else
 			if (!imm32)
 				return -EINVAL;
+#endif
 			if (priv_frame_ptr) {
 				push_r9(&prog);
 				ip += 2;
 			}
 			ip += x86_call_depth_emit_accounting(&prog, func, ip);
-			if (emit_call(&prog, func, ip))
+#ifdef CONFIG_UML
+			if (src_reg == BPF_PSEUDO_CALL)
+				err = emit_direct_call_or_placeholder(&prog, func, ip);
+			else
+				err = emit_call_or_indirect(&prog, func, ip);
+#else
+			err = emit_call(&prog, func, ip);
+#endif
+			if (err)
 				return -EINVAL;
 			if (priv_frame_ptr)
 				pop_r9(&prog);
@@ -3927,7 +4072,7 @@ struct bpf_prog *bpf_int_jit_compile(struct bpf_verifier_env *env, struct bpf_pr
 		if (!padding && pass >= PADDING_PASSES)
 			padding = true;
 		proglen = do_jit(env, prog, addrs, image, rw_image, oldproglen,
-				 &ctx, padding);
+				 &ctx, padding, extra_pass);
 		if (proglen <= 0) {
 out_image:
 			image = NULL;
@@ -4045,6 +4190,13 @@ bool bpf_jit_supports_kfunc_call(void)
 	return true;
 }
 
+#ifdef CONFIG_UML
+bool bpf_jit_supports_far_kfunc_call(void)
+{
+	return true;
+}
+#endif
+
 bool bpf_jit_supports_stack_args(void)
 {
 	return true;
@@ -4052,8 +4204,19 @@ bool bpf_jit_supports_stack_args(void)
 
 void *bpf_arch_text_copy(void *dst, void *src, size_t len)
 {
+#ifdef CONFIG_UML
+	/*
+	 * UML doesn't provide real text patching infrastructure. The
+	 * verification-oriented JIT path already uses memcpy-based shims for
+	 * text pokes, so avoid routing final JIT image copies through UML's
+	 * WARN_ON(1) text_poke() stub.
+	 */
+	if (!memcpy(dst, src, len))
+		return ERR_PTR(-EINVAL);
+#else
 	if (text_poke_copy(dst, src, len) == NULL)
 		return ERR_PTR(-EINVAL);
+#endif
 	return dst;
 }
 
diff --git a/arch/x86/um/Kconfig b/arch/x86/um/Kconfig
index 44b12e45f..7b617d450 100644
--- a/arch/x86/um/Kconfig
+++ b/arch/x86/um/Kconfig
@@ -13,6 +13,8 @@ config UML_X86
 	select ARCH_USE_QUEUED_SPINLOCKS
 	select DCACHE_WORD_ACCESS
 	select HAVE_EFFICIENT_UNALIGNED_ACCESS
+	select HAVE_EBPF_JIT if 64BIT
+	select ARCH_WANT_DEFAULT_BPF_JIT if 64BIT
 	select UML_SUBARCH_SUPPORTS_SMP if X86_CX8
 
 config 64BIT
diff --git a/arch/x86/um/asm/nops.h b/arch/x86/um/asm/nops.h
new file mode 100644
index 000000000..cbd8aadb9
--- /dev/null
+++ b/arch/x86/um/asm/nops.h
@@ -0,0 +1,7 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+#ifndef __UM_X86_NOPS_H
+#define __UM_X86_NOPS_H
+
+#include "../../include/asm/nops.h"
+
+#endif
diff --git a/arch/x86/um/asm/segment.h b/arch/x86/um/asm/segment.h
index 2ef507bc6..138fdde0e 100644
--- a/arch/x86/um/asm/segment.h
+++ b/arch/x86/um/asm/segment.h
@@ -8,4 +8,19 @@ extern int host_gdt_entry_tls_min;
 #define GDT_ENTRY_TLS_MIN host_gdt_entry_tls_min
 #define GDT_ENTRY_TLS_MAX (GDT_ENTRY_TLS_MIN + GDT_ENTRY_TLS_ENTRIES - 1)
 
+#ifdef CONFIG_X86_64
+#define GDT_ENTRY_KERNEL32_CS		1
+#define GDT_ENTRY_KERNEL_CS		2
+#define GDT_ENTRY_KERNEL_DS		3
+#define GDT_ENTRY_DEFAULT_USER32_CS	4
+#define GDT_ENTRY_DEFAULT_USER_DS	5
+#define GDT_ENTRY_DEFAULT_USER_CS	6
+#define __KERNEL32_CS			(GDT_ENTRY_KERNEL32_CS * 8)
+#define __KERNEL_CS			(GDT_ENTRY_KERNEL_CS * 8)
+#define __KERNEL_DS			(GDT_ENTRY_KERNEL_DS * 8)
+#define __USER32_CS			(GDT_ENTRY_DEFAULT_USER32_CS * 8 + 3)
+#define __USER_DS			(GDT_ENTRY_DEFAULT_USER_DS * 8 + 3)
+#define __USER_CS			(GDT_ENTRY_DEFAULT_USER_CS * 8 + 3)
+#endif
+
 #endif
diff --git a/arch/x86/um/asm/vsyscall.h b/arch/x86/um/asm/vsyscall.h
new file mode 100644
index 000000000..c08303d8b
--- /dev/null
+++ b/arch/x86/um/asm/vsyscall.h
@@ -0,0 +1,7 @@
